# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# --- Supabase (create a NEW project for this Major Project) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Groq (client-side — no backend, matches the reference project) ---
# This key ships inside the browser bundle. That's a known trade-off for
# this assignment's scope, not something to use in a real production app
# with a Groq bill you care about.
VITE_GROQ_API_KEY=

# Optional — override which Groq models are used. Defaults are set in
# src/lib/groq.js if these are left blank. Groq periodically retires model
# names — if a scan or chat request ever errors with "model_decommissioned",
# check https://console.groq.com/docs/deprecations for the current
# replacement and either set it here or update the fallback in
# src/lib/groq.js.
VITE_GROQ_VISION_MODEL=qwen/qwen3.6-27b
VITE_GROQ_TEXT_MODEL=openai/gpt-oss-120b

# --- Resend (kept server-side) ---
# Used by vite.config.js (dev proxy) and api/resend/emails.js (prod).
# Deliberately has NO VITE_ prefix — must never reach the browser bundle.
RESEND_API_KEY=

# --- Only needed for the automatic weekly cron job, once deployed to Vercel ---
# (api/send-report.js + api/weekly-cron.js). Not required for local dev —
# the manual "Send Now" button works without these.
SUPABASE_SERVICE_ROLE_KEY=
